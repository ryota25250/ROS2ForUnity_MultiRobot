  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 76add797bdb1d8c4b8276633f6e67167, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  PluginText: "<gazebo reference=\"front_lrf_link\">\n  <sensor name=\"front_lrf_sensor\"
    type=\"ray\">\n    <pose>0 0 0 0 0 0</pose>\n    <visualize>true</visualize>\n   
    <update_rate>40</update_rate>\n    <ray>\n      <scan>\n        <horizontal>\n         
    <samples>720</samples>\n          <resolution>1</resolution>\n          <min_angle>-1.65806278939</min_angle>\n         
    <max_angle>1.65806278939</max_angle>\n        </horizontal>\n      </scan>\n     
    <range>\n        <min>0.1</min>\n        <max>60.0</max>\n        <resolution>0.01</resolution>\n     
    </range>\n      <noise>\n        <type>gaussian</type>\n        <mean>0.0</mean>\n       
    <stddev>0.03</stddev>\n      </noise>\n    </ray>\n    <plugin filename=\"libgazebo_ros_laser.so\"
    name=\"gazebo_ros_front_lrf_controller\">\n      <topicName>front/scan</topicName>\n     
    <frameName>front_lrf_link</frameName>\n    </plugin>\n  </sensor>\n</gazebo>"
